# API
VITE_API_URL=http://localhost:4000

# WalletConnect (get a project id at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# 0G chain id (16661 = 0G mainnet, 16602 = 0G Galileo testnet, 16600 = 0G Newton testnet)
VITE_OG_CHAIN_ID=16602

# Optional contract addresses (read from deployments/registry.json if unset)
VITE_AGENT_REGISTRY_ADDRESS=
VITE_MEMORY_REGISTRY_ADDRESS=
VITE_PROOF_VERIFIER_ADDRESS=
