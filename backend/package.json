{
  "name": "aevum-backend",
  "version": "0.1.0",
  "description": "Aevum — decentralized AI agent memory infrastructure backend (0G Buildathon)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:storage": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/lib/ogStorage.test.ts",
    "test:compute": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/lib/ogCompute.test.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@0gfoundation/0g-compute-ts-sdk": "^0.8.4",
    "@0glabs/0g-ts-sdk": "^0.3.3",
    "cors": "^2.8.5",
    "ethers": "^6.13.4",
    "express": "^5.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "siwe": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
